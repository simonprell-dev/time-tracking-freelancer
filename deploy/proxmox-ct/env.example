# Copy to /etc/time-tracker/time-tracker.env on the CT.
# Generate a strong value with: openssl rand -hex 32
JWT_SECRET=change-this-secret

# The install script creates this database/user/password by default.
DATABASE_URL=host=127.0.0.1 user=timetracker password=timetracker dbname=timetracker port=5432 sslmode=disable

# The Go service listens only on localhost; Nginx exposes it.
PORT=8080
GIN_MODE=release

